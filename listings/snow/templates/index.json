        },
        "testimonial-2": {
          "type": "testimonial",
          "settings": {
            "show_rating": true,
            "rating": 5,
            "author": "Chase S., golfer",
            "title": "Perfect for chilly mornings, the Trail fleece delivers warmth without bulk. Its quick-dry fabric and ergonomic cut make it a reliable companion for running or layering during hikes.",
            "heading_tag": "h5",
            "position": "place-self-end-start"
          }
