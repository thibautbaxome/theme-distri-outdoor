{
  "sections": {
    "slideshow": {
      "type": "slideshow",
      "settings": {
        "allow_transparent_header": true,
        "image_size": "auto",
        "transition_type": "fade",
        "autoplay": true,
        "pause_auto_rotate_on_hover": false,
        "cycle_speed": 6,
        "background": "#000000"
      },
      "blocks": {
        "slideshow-image-slide-1": {
          "type": "_slideshow-image-slide",
          "settings": {
            "color_scheme": "scheme-3",
            "slide_link": "shopify://collections/all",
            "content_max_width": 720,
            "mobile_content_position": "place-self-center-start",
            "desktop_content_position": "sm:place-self-center-start",
            "overlay_color": "#000000",
            "overlay_opacity": 0
          },
          "blocks": {
            "heading-1": {
              "type": "heading",
              "settings": {
                "text": "Clean products",
                "heading_size": "display-m",
                "html_tag": "p",
                "indent": "none",
                "highlight_effect": "circle_pencil"
              }
            },
            "rich-text-1": {
              "type": "rich-text",
              "settings": {
                "text": "<p>Committed to sustainable beauty and minimize our impact on the planet.</p>",
                "content_width": "xs"
              }
            },
            "button-1": {
              "type": "button",
              "settings": {
                "text": "Discover our products",
                "open_in_new_tab": false,
                "style": "solid"
              }
            }
          },
          "block_order": [
            "heading-1",
            "rich-text-1",
            "button-1"
          ]
        },
        "slideshow-image-slide-2": {
          "type": "_slideshow-image-slide",
          "settings": {
            "color_scheme": "scheme-3",
            "content_max_width": 780,
            "mobile_content_position": "place-self-center-start",
            "desktop_content_position": "sm:place-self-center-start",
            "overlay_color": "#000000",
            "overlay_opacity": 10
          },
          "blocks": {
            "heading-1": {
              "type": "heading",
              "settings": {
                "text": "Ethical beauty",
                "heading_size": "display-m",
                "html_tag": "p",
                "indent": "none",
                "highlight_effect": "underline_pencil",
                "highlight_accent_color": "#ffffff"
              }
            },
            "rich-text-1": {
              "type": "rich-text",
              "settings": {
                "text": "<p>Our products are not tested on animals.</p>",
                "content_width": "sm"
              }
            },
            "button-1": {
              "type": "button",
              "settings": {
                "text": "About us",
                "open_in_new_tab": false,
                "style": "solid"
              }
            }
          },
          "block_order": [
            "heading-1",
            "rich-text-1",
            "button-1"
          ]
        },
        "slideshow-image-slide-3": {
          "type": "_slideshow-image-slide",
          "settings": {
            "color_scheme": "scheme-3",
            "content_max_width": 720,
            "mobile_content_position": "place-self-center-start",
            "desktop_content_position": "sm:place-self-center-start",
            "overlay_color": "#000000",
            "overlay_opacity": 10
          },
          "blocks": {
            "heading-1": {
              "type": "heading",
              "settings": {
                "text": "Transform your skin",
                "heading_size": "display-m",
                "html_tag": "p",
                "indent": "none",
                "highlight_effect": "default",
                "highlight_text_color": "rgba(0,0,0,0)"
              }
            },
            "rich-text-1": {
              "type": "rich-text",
              "settings": {
                "text": "<p>Tone your skin and reduce cellulite with our body selection.</p>",
                "content_width": "xs"
              }
            },
            "button-1": {
              "type": "button",
              "settings": {
                "text": "Shop Beauty tools",
                "open_in_new_tab": false,
                "style": "solid"
              }
            }
          },
          "block_order": [
            "heading-1",
            "rich-text-1",
            "button-1"
          ]
        },
        "slideshow-controls-1": {
          "type": "_slideshow-controls",
          "static": true,
          "settings": {
            "controls_style": "dot",
            "controls_color": "#ffffff"
          }
        }
      },
      "block_order": [
        "slideshow-image-slide-1",
        "slideshow-image-slide-2",
        "slideshow-image-slide-3"
      ]
