        "dynamic-grid-item-1": {
          "type": "_dynamic-grid-item",
          "settings": {
            "visibility": "both",
            "text_alignment": "left",
            "desktop_row_start": 2,
            "desktop_column_start": 1,
            "desktop_column_end": 6,
            "desktop_horizontal_adjustment": 0,
            "desktop_vertical_adjustment": 0,
            "mobile_row_start": 2,
            "mobile_column_start": 1,
            "mobile_column_end": 8,
            "mobile_horizontal_adjustment": 0,
            "mobile_vertical_adjustment": 0,
            "parallax_speed": 2,
            "parallax_direction": "vertical"
