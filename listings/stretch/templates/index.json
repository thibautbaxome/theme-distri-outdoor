                "font_size_desktop": 4,
                "font_size_mobile": 9,
                "font_size_line_height": 0.9,
                "html_tag": "p",
                "indent": "none",
                "highlight_effect": "underline_pencil"
              }
            },
            "rich-text-1": {
              "type": "rich-text",
              "settings": {
                "text": "<p>Ingredient sourcing is a crucial step, reflecting our commitment to quality and ethics. We carefully select precious, natural active ingredients from the best organic crops and wild harvesting. Our raw ingredients are chosen for their exceptional properties on the skin.</p>",
                "content_width": "xs"
              }
            },
            "button-1": {
              "type": "button",
              "settings": {
                "text": "All ingredients",
                "url": "shopify://collections/all",
                "open_in_new_tab": false,
                "style": "outline"
              }
            }
          },
          "block_order": [
            "dynamic-grid-heading-1",
            "rich-text-1",
            "button-1"
          ]
        },
        "dynamic-grid-item-2": {
          "type": "_dynamic-grid-item",
          "settings": {
            "visibility": "desktop_only",
            "text_alignment": "left",
            "desktop_row_start": 7,
