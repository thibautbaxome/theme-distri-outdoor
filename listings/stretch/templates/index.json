    "dynamic-grid": {
      "type": "dynamic-grid",
      "settings": {
        "color_scheme": "scheme-1",
        "allow_transparent_header": true,
        "show_background_image_parallax": false,
        "add_vertical_spacing": true,
        "add_horizontal_spacing": true,
        "gap": 16,
        "mobile_gap": 10,
        "overlay_color": "#000000",
        "overlay_opacity": 0
