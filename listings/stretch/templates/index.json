    "featured-collections": {
      "type": "featured-collections",
      "settings": {
        "stack_products_mobile": false,
        "stack_products_desktop": false,
        "products_per_row_mobile": "2",
        "products_per_row_desktop": 4,
        "tabs_alignment": "start",
        "tabs_icon": "circle",
        "show_view_all_button": false,
        "show_scrolling_bar": true
      },
      "blocks": {
        "collection-1": {
          "type": "collection",
          "settings": {
            "products_count": 6,
            "title": "best sellers",
            "link": "{{ block.settings.collection.url }}"
          }
        },
        "collection-2": {
          "type": "collection",
          "settings": {
            "products_count": 6,
            "title": "trending now",
            "link": "{{ block.settings.collection.url }}"
          }
        }
      },
      "block_order": [
        "collection-1",
        "collection-2"
      ]
    },
