{%- comment -%}
  FAQ de collection : lit le métachamp custom.faq (JSON) de la collection et l'affiche en accordéons.
  Le schéma FAQPage correspondant est injecté dans snippets/microdata-schema.liquid.
{%- endcomment -%}

{%- assign faq = collection.metafields.custom.faq.value -%}

{%- if faq != blank -%}
  <div class="color-scheme color-scheme--{{ section.settings.color_scheme.id }}">
    <div class="container section-spacing">
      <div class="section-stack">
        {%- if section.settings.title != blank -%}
          <h2 class="{{ section.settings.heading_size }}">{{ section.settings.title }}</h2>
        {%- endif -%}

        <div class="prose">
          {%- for item in faq -%}
            <details style="border-top: 1px solid rgb(var(--text-color) / 0.15); padding: 1rem 0;">
              <summary style="cursor: pointer; font-weight: 600;">{{ item.question }}</summary>
              <div style="margin-block-start: 0.6rem;"><p>{{ item.answer }}</p></div>
            </details>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Collection FAQ",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:global.colors.scheme",
      "default": "scheme-1"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "t:global.text.heading",
      "default": "Questions fréquentes"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:global.text.heading_size",
      "default": "h3",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" }
      ]
    }
  ],
  "presets": [{ "name": "Collection FAQ" }]
}
{% endschema %}
