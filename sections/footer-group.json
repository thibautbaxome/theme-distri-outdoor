{
  "type": "footer",
  "name": "Footer group",
  "sections": {
    "trust-icons": {
      "type": "trust-icons",
      "blocks": {
        "item-1": {
          "type": "item",
          "settings": {
            "title": "Spécialiste de l'outdoor",
            "content": "Braseros, kamados, anti-moustiques & mobilier."
          }
        },
        "item-2": {
          "type": "item",
          "settings": {
            "title": "Livraison en France",
            "content": "Expédition suivie sous 48h ouvrées."
          }
        },
        "item-3": {
          "type": "item",
          "settings": {
            "title": "Conseils d'experts",
            "content": "Une équipe à votre écoute du lundi au vendredi."
          }
        },
        "item-4": {
          "type": "item",
          "settings": {
            "title": "Paiement sécurisé",
            "content": "Vos transactions sont protégées."
          }
        }
      },
      "block_order": [
        "item-1",
        "item-2",
        "item-3",
        "item-4"
      ],
      "settings": {
        "color_scheme": "scheme-2"
      }
    },
    "footer": {
      "type": "footer",
      "blocks": {
        "newsletter": {
          "type": "newsletter",
          "settings": {
            "image": "{{shop.brand.logo}}",
            "image_width": 150,
            "heading_size": "h3",
            "title": "Newsletter",
            "content": "<p>Recevez nos nouveautés et offres exclusives.</p>",
            "disclaimer_text": "<p>En vous inscrivant, vous acceptez notre politique de confidentialité.</p>"
          }
        },
        "links": {
          "type": "links",
          "settings": {
            "menu": "footer-boutique",
            "menu_title": "Boutique",
            "show_menu_title": true,
            "collapse_on_mobile": true
          }
        },
        "links_infos": {
          "type": "links",
          "settings": {
            "menu": "footer-infos",
            "menu_title": "Informations",
            "show_menu_title": true,
            "collapse_on_mobile": true
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "title": "À propos",
            "content": "<p>Distri-Outdoor, votre spécialiste de l'extérieur : braseros-planchas, kamados, bornes anti-moustiques et mobilier de jardin. Une sélection exigeante pour transformer chaque terrasse en lieu de partage.</p>",
            "enable_follow_on_shop": true
          }
        }
      },
      "block_order": [
        "newsletter",
        "links",
        "links_infos",
        "text"
      ]
    }
  },
  "order": [
    "trust-icons",
    "footer"
  ]
}
