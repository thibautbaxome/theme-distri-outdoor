{%- doc -%}
Returns the text direction (ltr or rtl) based on the current locale's language code.
{%- enddoc -%}

{%- assign language_code = request.locale.iso_code | split: '-' | first -%}

{%- case language_code -%}
  {%- when 'ae' or 'ar' or 'arc' or 'bcc' or 'bqi' or 'ckb' or 'dv' or 'fa' or 'glk' or 'ha' or 'he' or 'kwh' or 'ks' or 'ku' or 'mzn' or 'nqo' or 'pnb' or 'ps' or 'sd' or 'ug' or 'ur' or 'yi' -%}
    rtl
  {%- else -%}
    ltr
{%- endcase -%}