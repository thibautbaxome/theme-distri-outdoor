{%- doc -%}
This component is used to create the necessary markup to create an input checkbox

@param {string} name - the HTML name attribute that is used when the field is submitted.
@param {string} [type] - by default the snippet generates a checkbox, but you can pass a "radio" type to generate radio buttons
@param {string} [form] - if specified, define the form ID linked to this input
@param {boolean} [checked] - if the checkbox is checked or not
@param {boolean} [disabled] - if the checkbox is disabled or not
@param {boolean} [required] - if the checkbox needs to be checked or not
@param {string} [value] - the value to use (use 1 if none is passed)
@param {boolean} [switch] - if set to true, the checkbox is rendered as a switch
@param {string} [label] - the label to show
@param {string} [id_prefix] - an optional prefix to be used to dissociate the ID
@param {object} [block]
@param {object} [section]
{%- enddoc -%}

{%- capture id -%}checkbox-{{ id_prefix }}-{{ section.id }}-{{ form }}-{{ name }}-{{ value | handle }}{%- endcapture -%}

{%- capture optional_attributes -%}
  {% if form %}form="{{ form }}"{% endif %}
  {% if value %}value="{{ value | default: 1 }}"{% endif %}
  {% if disabled %}disabled{% endif %}
  {% if required %}required{% endif %}
  {% if checked %}checked{% endif %}
{%- endcapture -%}

<div class="checkbox-control {% if settings.input_uppercase %}subheading{% endif %}" {{ block.shopify_attributes }}>
  {%- if switch -%}
    <input id="{{ id | escape }}" class="switch" type="{{ type | default: 'checkbox' }}" role="switch" name="{{ name }}" {{ optional_attributes }}>
  {%- else -%}
    <input id="{{ id | escape }}" class="{% if type == 'radio' %}radio{% else %}checkbox{% endif %}" type="{{ type | default: 'checkbox' }}" name="{{ name }}" {{ optional_attributes }}>
  {%- endif -%}

  {%- if label != blank -%}
    <label for="{{ id | escape }}">{{ label }}</label>
  {%- endif -%}
</div>