{%- doc -%}
This snippet generate an input (or a textarea text field if the "multiline" option is passed

@param {string} name - the HTML name attribute that is used when the field is submitted
@param {string} [type] - the HTML type to use (such as "email", "password"...). If none is passed, "text" is assumed
@param {string} [value] - the default value (if any) for the setting
@param {string} [form] - if specified, define the form ID linked to this input
@param {string} [label] - the label to show
@param {boolean} [label_hidden] - if set to true, the label is visually hidden, but still visible for accesibility
@param {boolean} [show_label_as_block] - if set to true, the label is shown as a block instead
@param {number} [minlength] - an optional min length for input
@param {number} [maxlength] - an optional max length for input
@param {string} [pattern] - an optional pattern for validation purpose
@param {number} [multiline] - the number of line to show (if specified, the input is set as a textarea)
@param {string} [placeholder] - the placeholder will only be visible if the label is show as a block or hidden, otherwise it is ignored
@param {boolean} [required] - if set to true, the "required" attribute is added to the input
@param {boolean} [disabled] - check if the field is disabled
@param {boolean} [show_max_characters_count] - if set to true, a text will appear below the input to show the maximum count
@param {number} [tabindex] - set a custom tabindex attribute
@param {string} [autocomplete] - a hint to the browser for help autocompletion. List can be found here: https://developer.mozilla.org/en-US/docs/Web/HTML/Attributes/autocomplete#values
@param {string} [autocapitalize] - a hint for auto capitalization
@param {string} [autocorrect] - an optional hint for browser auto correct (Safari only)
@param {string} [enterkeyhint] - an optional hint for indicate the browser which button to show on the virtual keyboard
@param {string} [id_prefix] - an optional prefix to be used to dissociate the ID
@param {string} [alignment] - the content alignment for options (can be "start", "center" or "end") - default to start
@param {object} [block]
@param {object} [section]
{%- enddoc -%}

{%- capture id -%}input-{{ id_prefix }}-{{ section.id }}-{{ form }}-{{ name | handle }}{%- endcapture -%}

{%- capture optional_attributes -%}
  {% if form %}form="{{ form }}"{% endif %}
  {% if value and multiline == blank %}value="{{ value | escape }}"{% endif %}
  {% if tabindex %}tabindex="{{ tabindex }}"{% endif %}
  {% if minlength and minlength > 0 %}minlength="{{ minlength }}"{% endif %}
  {% if maxlength and maxlength > 0 %}maxlength="{{ maxlength }}"{% endif %}
  {% if placeholder != blank and show_label_as_block or label_hidden %}placeholder="{{ placeholder | escape }}"{% else %}placeholder=" "{% endif %}
  {% if autocomplete %}autocomplete="{{ autocomplete }}"{% endif %}
  {% if autocapitalize %}autocapitalize="{{ autocapitalize }}"{% endif %}
  {% if enterkeyhint %}enterkeyhint="{{ enterkeyhint }}"{% endif %}
  {% if required %}required{% endif %}
  {% if disabled %}disabled{% endif %}
  {% if autocorrect %}autocorrect="{{ autocorrect }}"{% endif %}
  {% if pattern %}pattern="{{ pattern }}"{% endif %}
{%- endcapture -%}

{%- if type == 'hidden' -%}
  <input type="hidden" name="{{ name }}" value="{{ value | escape }}">
{%- else -%}
  <div class="form-control" {{ block.shopify_attributes }}>
    {%- if label != blank and show_label_as_block or label_hidden -%}
      <label for="{{ id }}" class="text-subdued {% if label_hidden %}sr-only{% else %}justify-self-{{ alignment | default: 'start' }}{% endif %}">{{ label }}</label>
    {%- endif -%}

    {%- if multiline != blank -%}
      <textarea id="{{ id }}" class="textarea {% if settings.input_uppercase %}subheading{% endif %}" name="{{ name }}" rows="{{ multiline }}" {{ optional_attributes }} style="--textarea-min-rows: {{ multiline }}">{{- value -}}</textarea>
    {%- else -%}
      <input id="{{ id }}" class="input {% if settings.input_uppercase %}subheading{% endif %}" type="{{ type | default: 'text' }}" {% if type == 'email' or type == 'tel' %}dir="ltr"{% endif %} name="{{ name }}" {{ optional_attributes }}>
    {%- endif -%}

    {%- if label != blank and show_label_as_block != true and label_hidden != true -%}
      <label for="{{ id }}" class="floating-label {% if settings.input_uppercase %}subheading{% endif %}">{{ label }}</label>
    {%- endif -%}

    {%- if show_max_characters_count and maxlength > 0 -%}
      <span class="form-control__max-characters-count subheading text-subdued text-end">{{ 'general.form.max_characters' | t: max_chars: maxlength }}</span>
    {%- endif -%}
  </div>
{%- endif -%}
