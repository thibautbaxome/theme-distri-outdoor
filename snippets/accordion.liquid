{%- doc -%}
This component is used to create an accordion (also called as collapsible). It internally uses the "details" HTML
tag so that it can also be used without any JavaScript.

@param {string} title - the title to use for the toggle button
@param {string} content - the hidden content inside the accordion
@param {string} [icon] - the name of an icon that come built-in with the theme
@param {string} [custom_icon] - an optional icon image added next to the title
@param {number} [icon_width] - an optional icon width (default: 20)
@param {number} [mobile_icon_width] - an optional icon width on mobile (default: 16)
@param {boolean} [uppercase_title] - if set to true, the title of the collapsible is automatically uppercased
@param {boolean} [subheading_title] - if set to true, the title of the collapsible is considered as a subheading
@param {boolean} [open] - if set to true the accordion is open by default
@param {boolean} [large] - if set to true, a bigger version of the accordion is shown
@param {string} [title_size] - if set to true, only the title is shown bigger
@param {boolean} [prose_content] - if set to true, the content is considered as prose and the associated class is added
@param {boolean} [use_secondary_background] - if set to true, the background of the accordion is set to the secondary color
@param {string} [class] - extra class to add on the parent
@param {object} [block] - an optional block to output theme editor attributes
{%- enddoc -%}

<accordion-disclosure class="accordion {% if large %}accordion--large{% endif %} {% if use_secondary_background %}bg-secondary{% endif %} {{ class }}" {{ block.shopify_attributes }}>
  <details class="accordion__disclosure" {% if open %}open{% endif %} >
    <summary class="accordion__summary {% if title_size == 'lg' %}text-lg{% endif %} {% if uppercase_title %}uppercase{% endif %} {% if subheading_title %}subheading{% endif %}">
      {%- if icon != blank or custom_icon != blank -%}
        <div class="text-with-icon">
          {%- liquid
            assign icon_width = icon_width | default: 20
            assign mobile_icon_width = mobile_icon_width | default: 16

            if custom_icon != blank
              render 'icon', image: custom_icon, width: icon_width, mobile_width: mobile_icon_width, class: 'accordion__title-icon'
            elsif icon != blank and icon != 'none'
              render 'icon' with icon, width: icon_width, mobile_width: mobile_icon_width, class: 'accordion__title-icon'
            endif

            echo '<span>' | append: title | append: '</span>'
          -%}
        </div>
      {%- else -%}
        <span>{{- title -}}</span>
      {%- endif -%}

      {%- liquid
        render 'icon' with 'accordion-small-arrow'
      -%}
    </summary>

    <div class="accordion__content {% if prose_content %}prose{% endif %}">
      {{- content -}}
    </div>
  </details>
</accordion-disclosure>
