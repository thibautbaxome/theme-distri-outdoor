{
  "sections": {
    "hero": {
      "type": "slideshow",
      "blocks": {
        "slide_main": {
          "type": "_slideshow-image-slide",
          "settings": {
            "image": "shopify://shop_images/Capture_d_ecran_2026-03-25_a_14.42.13.jpg",
            "color_scheme": "scheme-4",
            "content_max_width": 1100,
            "mobile_content_position": "place-self-end",
            "desktop_content_position": "sm:place-self-end-start",
            "overlay_color": "#1B1714",
            "overlay_opacity": 35
          },
          "blocks": {
            "slide_sub": {
              "type": "subheading",
              "settings": {
                "text": "Spécialiste de l'extérieur"
              }
            },
            "slide_heading": {
              "type": "heading",
              "settings": {
                "text": "Votre extérieur à portée de main",
                "heading_size": "display-l",
                "html_tag": "h1",
                "indent": "none",
                "highlight_effect": "default"
              }
            },
            "slide_text": {
              "type": "rich-text",
              "settings": {
                "text": "<p>Une sélection de produits français de qualité pour vos espaces extérieurs.</p>"
              }
            },
            "slide_btn": {
              "type": "button",
              "settings": {
                "text": "Découvrir la boutique",
                "url": "/collections/braseros-kamados-borne",
                "style": "solid"
              }
            }
          },
          "block_order": [
            "slide_sub",
            "slide_heading",
            "slide_text",
            "slide_btn"
          ]
        },
        "controls": {
          "type": "_slideshow-controls",
          "static": true,
          "settings": {
            "controls_style": "line",
            "controls_color": "#F3ECE1"
          }
        }
      },
      "block_order": [
        "slide_main"
      ],
      "settings": {
        "allow_transparent_header": true,
        "image_size": "lg",
        "transition_type": "fade",
        "autoplay": false,
        "cycle_speed": 6,
        "background": "#1B1714"
      }
    },
    "univers": {
      "type": "collection-list",
      "blocks": {
        "section-header": {
          "type": "_section-header",
          "static": true,
          "settings": {
            "subheading": "La boutique",
            "title": "Nos univers",
            "content": "<p>Braseros, kamados, mobilier, anti-moustiques : tout pour vivre dehors.</p>",
            "heading_size": "h2",
            "text_alignment": "center"
          }
        },
        "u1": {
          "type": "collection-card",
          "settings": {
            "collection": "braseros"
          }
        },
        "u2": {
          "type": "collection-card",
          "settings": {
            "collection": "kamados"
          }
        },
        "u3": {
          "type": "collection-card",
          "settings": {
            "collection": "borne-anti-moustique"
          }
        },
        "u4": {
          "type": "collection-card",
          "settings": {
            "collection": "accessoires"
          }
        }
      },
      "block_order": [
        "u1",
        "u2",
        "u3",
        "u4"
      ],
      "settings": {
        "color_scheme": "scheme-1",
        "items_per_row": 4,
        "stack_on_mobile": true
      }
    },
    "carousel_braseros": {
      "type": "featured-collections",
      "blocks": {
        "c1": {
          "type": "collection",
          "settings": {
            "collection": "braseros",
            "title": "Nos braseros",
            "content": "<p>La gamme BRAZIR, fabriquée en France.</p>",
            "link": "/collections/braseros",
            "products_count": 6
          }
        }
      },
      "block_order": [
        "c1"
      ],
      "settings": {
        "color_scheme": "scheme-1",
        "products_per_row_mobile": "2",
        "products_per_row_desktop": 4,
        "stack_products_desktop": false,
        "stack_products_mobile": false,
        "tabs_alignment": "start",
        "tabs_icon": "none",
        "show_view_all_button": true,
        "show_scrolling_bar": true
      }
    },
    "carousel_accessoires": {
      "type": "featured-collections",
      "blocks": {
        "c1": {
          "type": "collection",
          "settings": {
            "collection": "accessoires-braseros",
            "title": "Les accessoires",
            "content": "<p>Grilles, plancha, four à pizza, housses…</p>",
            "link": "/collections/accessoires-braseros",
            "products_count": 8
          }
        }
      },
      "block_order": [
        "c1"
      ],
      "settings": {
        "color_scheme": "scheme-1",
        "products_per_row_mobile": "2",
        "products_per_row_desktop": 4,
        "stack_products_desktop": false,
        "stack_products_mobile": false,
        "tabs_alignment": "start",
        "tabs_icon": "none",
        "show_view_all_button": true,
        "show_scrolling_bar": true
      }
    },
    "concept": {
      "type": "text-with-media",
      "blocks": {
        "sub": {
          "type": "subheading",
          "settings": {
            "text": "Notre concept"
          }
        },
        "h": {
          "type": "heading",
          "settings": {
            "text": "Des produits qui créent des moments",
            "heading_tag": "h2"
          }
        },
        "rt": {
          "type": "richtext",
          "settings": {
            "text": "<p>Chez Distri-Outdoor, nous sélectionnons des produits français de qualité pour vos espaces extérieurs. Notre objectif : allier durabilité, design et convivialité, et transformer chaque terrasse ou jardin en un lieu de partage.</p>"
          }
        },
        "btn": {
          "type": "button",
          "settings": {
            "text": "La boutique",
            "url": "/collections/catalogue",
            "style": "solid"
          }
        }
      },
      "block_order": [
        "sub",
        "h",
        "rt",
        "btn"
      ],
      "settings": {
        "color_scheme": "scheme-1",
        "primary_image": "shopify://shop_images/DSC0028.jpg"
      }
    },
    "modularite": {
      "type": "text-with-icons",
      "blocks": {
        "m1": {
          "type": "item",
          "settings": {
            "title": "Choisissez la taille",
            "heading_tag": "h3",
            "content": "<p>Du compact à l’XL, selon votre espace.</p>"
          }
        },
        "m2": {
          "type": "item",
          "settings": {
            "title": "Choisissez la forme",
            "heading_tag": "h3",
            "content": "<p>Rond, carré, octogonal, hexagonal.</p>"
          }
        },
        "m3": {
          "type": "item",
          "settings": {
            "title": "Ajoutez vos accessoires",
            "heading_tag": "h3",
            "content": "<p>Grilles, plancha, four à pizza, housse…</p>"
          }
        }
      },
      "block_order": [
        "m1",
        "m2",
        "m3"
      ],
      "settings": {
        "color_scheme": "scheme-6",
        "subheading": "Modulable",
        "title": "Un brasero qui vous ressemble",
        "content": "<p>Composez le vôtre : la taille, la forme, puis les accessoires de cuisson.</p>",
        "heading_tag": "h2",
        "items_per_row_desktop": 3,
        "stack_on_mobile": true
      }
    },
    "faq": {
      "type": "faq",
      "blocks": {
        "q1": {
          "type": "question",
          "settings": {
            "question": "Livrez-vous partout en France ?",
            "answer": "<p>Oui, nous livrons en France métropolitaine. Les frais de port sont calculés au paiement.</p>"
          }
        },
        "q2": {
          "type": "question",
          "settings": {
            "question": "Vos braseros sont-ils fabriqués en France ?",
            "answer": "<p>Oui, les braseros BRAZIR sont fabriqués en France et garantis 5 ans.</p>"
          }
        },
        "q3": {
          "type": "question",
          "settings": {
            "question": "Puis-je personnaliser mon brasero ?",
            "answer": "<p>Oui : la taille, la forme et les accessoires de cuisson se choisissent sur chaque fiche produit.</p>"
          }
        },
        "q4": {
          "type": "question",
          "settings": {
            "question": "Proposez-vous la location ?",
            "answer": "<p>Oui, louez un brasero pour vos événements. Découvrez nos services sur la page Location.</p>"
          }
        }
      },
      "block_order": [
        "q1",
        "q2",
        "q3",
        "q4"
      ],
      "settings": {
        "color_scheme": "scheme-1",
        "subheading": "FAQ",
        "title": "Questions fréquentes",
        "content": "",
        "button_text": "Toutes les questions",
        "button_url": "/pages/faq",
        "button_style": "outline"
      }
    },
    "newsletter": {
      "type": "newsletter",
      "settings": {
        "color_scheme": "scheme-4",
        "title": "Restez informé",
        "heading_tag": "h2",
        "button_text": "S'inscrire",
        "privacy_policy_text": "En vous inscrivant, vous acceptez notre politique de confidentialité."
      }
    }
  },
  "order": [
    "hero",
    "univers",
    "carousel_braseros",
    "concept",
    "modularite",
    "carousel_accessoires",
    "faq",
    "newsletter"
  ]
}
